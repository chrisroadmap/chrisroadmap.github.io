---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import chrisPhoto from '../images/valencia-sea.jpeg';

const pageTitle = "Chris Smith";
---
<BaseLayout pageTitle={pageTitle}>
    <h2>Chris Smith is a climate scientist at the University of Leeds, UK.</h2>
    <p>
		Chris is the lead developer of the reduced-complexity <a href="https://docs.fairmodel.net">fair climate model</a> and is part of the <a href="https://wcrp-cmip.org/cmip7-task-teams/ensemble-design/">Strategic Ensemble Design</a> Task Team and Radiative Forcing Model Intercomparison Project for CMIP7.
	</p>
    <Image
        src={chrisPhoto} 
        alt="Chris Smith, Valencia, 4 December 2023" 
        format="JPEG"
        style="height: 100%; width: 100%; max-width: 541px; object-fit: cover;"
    />
</BaseLayout>