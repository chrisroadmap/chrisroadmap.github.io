---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import chrisPhoto from '../images/egu-2024.jpg';

const pageTitle = "Chris Smith";
---
<BaseLayout pageTitle={pageTitle}>
    <h2>free spirit & loose cannon</h2>
    <p>
		take a look around. more coming soon.
	</p>
    <Image
        src={chrisPhoto} 
        alt="Chris Smith, EGU, 2024" 
        format="JPEG"
        style="height: 100%; width: 100%; max-width: 492px; object-fit: cover;"
    />
</BaseLayout>